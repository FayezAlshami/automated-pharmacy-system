VITE_APP_NAME=واجهة المريض - الصيدلية المؤتمتة
VITE_API_BASE_URL=http://localhost:3000/api
# ضع false للإنتاج مع السيرفر الحقيقي
VITE_USE_MOCK=false
# عنوان الـ ESP32 على الشبكة المحلية (مثال: http://192.168.4.1) — اتركه فارغاً لتعطيل الاستطلاع
VITE_ESP32_BASE_URL=
# اختياري: WebSocket للحالة اللحظية عند توفره في البرنامج الثابت
VITE_ESP32_WS_URL=
