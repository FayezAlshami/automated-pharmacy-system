# Public app configuration (Vite: only variables prefixed with VITE_ are exposed to the client)

VITE_APP_NAME=لوحة الأدمن والصيدلي - الصيدلية المؤتمتة

# Base URL for the REST API (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000/api

# When not "false", the app uses in-memory mock data and mock auth (default: true)
VITE_USE_MOCK=true

# Show demo credential hints on the login screen (dev: on unless set to "false"; production: off unless "true")
# VITE_SHOW_DEV_LOGIN_HINTS=false
